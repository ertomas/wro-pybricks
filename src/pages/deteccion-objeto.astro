---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Detección de objetos (Teachable Machine)">

  <!-- TensorFlow.js + Teachable Machine (imagen). Se cargan globales: tf, tmImage -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@1.7.0/dist/tf.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@teachablemachine/image@0.8.5/dist/teachablemachine-image.min.js"></script>

  <div class="max-w-3xl mx-auto px-4 py-8">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6 flex items-center gap-2">
      <a href={`${base}/`} class="hover:text-orange-500 transition-colors">Inicio</a>
      <span>/</span>
      <span class="text-gray-900 font-medium">Detección de objetos</span>
    </nav>

    <!-- Header -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 mb-6">
      <div class="flex items-start gap-4">
        <div class="bg-orange-500 text-white text-3xl rounded-xl w-14 h-14 flex items-center justify-center flex-shrink-0">
          🤖
        </div>
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl font-bold text-gray-900 mb-1">Reconocer un objeto con tu teléfono</h1>
          <p class="text-gray-600 text-sm">
            Entrená un modelo en <b>Teachable Machine</b>, pegá su link acá, y el teléfono le manda
            al hub <b>qué objeto ve</b> y <b>dónde está</b> en la imagen. Gratis y sin la app oficial.
          </p>
        </div>
      </div>
    </div>

    <!-- Aviso compatibilidad -->
    <div id="unsupported" class="hidden bg-red-50 border-l-4 border-red-400 rounded-r-xl p-4 mb-6">
      <p class="text-red-800 font-bold text-sm mb-1">⚠️ Este navegador no soporta Web Bluetooth</p>
      <p class="text-red-700 text-sm">
        Usá <b>Chrome</b> en Android (no funciona en Firefox ni en iPhone/Safari).
        La página tiene que abrirse por <b>https://</b> (o localhost).
      </p>
    </div>

    <!-- Modelo de Teachable Machine -->
    <div class="bg-white border border-gray-200 rounded-2xl p-5 mb-6">
      <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">
        Link del modelo de Teachable Machine
      </label>
      <div class="flex gap-2 flex-wrap">
        <input id="model-url" type="text" inputmode="url"
               placeholder="https://teachablemachine.withgoogle.com/models/XXXXXX/"
               class="flex-1 min-w-0 border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono" />
        <button id="btn-load-model"
                class="bg-orange-500 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-orange-600 transition-colors">
          Cargar modelo
        </button>
      </div>
      <p id="model-status" class="text-xs text-gray-500 mt-2">Todavía no se cargó ningún modelo.</p>
    </div>

    <!-- Panel de conexión -->
    <div class="bg-slate-900 text-white rounded-2xl p-5 mb-6">
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <div class="flex items-center gap-3">
          <span id="status-dot" class="w-3 h-3 rounded-full bg-slate-500"></span>
          <span id="status-text" class="text-sm font-medium text-slate-300">Desconectado</span>
        </div>
        <button id="btn-connect"
                class="bg-orange-500 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-orange-600 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
          Conectar hub
        </button>
      </div>
    </div>

    <!-- Cámara + lectura -->
    <div class="grid sm:grid-cols-2 gap-4 mb-6">

      <!-- Vista de cámara -->
      <div class="bg-black rounded-2xl overflow-hidden relative aspect-square">
        <video id="video" class="w-full h-full object-cover" playsinline autoplay muted></video>
        <!-- Mira central (para calibrar el color) -->
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
          <div class="w-16 h-16 border-2 border-white/70 rounded-lg"></div>
        </div>
        <!-- Marcador que sigue el centro horizontal del objeto (cx) -->
        <div id="cx-marker"
             class="absolute top-0 bottom-0 w-0.5 bg-orange-400 pointer-events-none hidden"
             style="left:50%"></div>
        <div id="cam-hint" class="absolute inset-0 flex items-center justify-center text-slate-400 text-sm text-center px-4">
          Tocá «Encender cámara» para empezar
        </div>
      </div>

      <!-- Lectura -->
      <div class="bg-white border border-gray-200 rounded-2xl p-5 flex flex-col">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Objeto detectado</p>

        <div class="mb-3">
          <div id="pred-name" class="text-xl font-bold text-gray-900">—</div>
          <div class="mt-1 h-2 bg-gray-100 rounded-full overflow-hidden">
            <div id="pred-bar" class="h-full bg-green-500 transition-all" style="width:0%"></div>
          </div>
          <div id="pred-conf" class="text-xs text-gray-500 mt-1 font-mono">confianza —</div>
        </div>

        <div class="grid grid-cols-2 gap-2 text-center mb-4">
          <div class="bg-gray-50 rounded-lg p-2">
            <div id="val-cx" class="text-lg font-bold text-gray-900 font-mono">—</div>
            <div class="text-[11px] text-gray-500 uppercase">centro X</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-2">
            <div id="val-area" class="text-lg font-bold text-gray-900 font-mono">—</div>
            <div class="text-[11px] text-gray-500 uppercase">tamaño</div>
          </div>
        </div>

        <div class="mt-auto space-y-2">
          <button id="btn-camera"
                  class="w-full bg-slate-700 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-slate-800 transition-colors">
            Encender cámara
          </button>
          <button id="btn-calibrate" disabled
                  class="w-full bg-slate-600 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-slate-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
            🎯 Fijar color del objeto (centrá la mira)
          </button>
          <button id="btn-stream" disabled
                  class="w-full bg-green-600 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-green-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
            ▶ Empezar a enviar
          </button>
        </div>
      </div>
    </div>

    <!-- Consola de depuración -->
    <details class="mb-8">
      <summary class="text-sm text-gray-500 cursor-pointer hover:text-gray-700">Ver registro técnico</summary>
      <pre id="log" class="mt-2 bg-slate-900 text-slate-300 text-xs rounded-xl p-3 h-32 overflow-auto font-mono"></pre>
    </details>

    <!-- Cómo se usa -->
    <div class="bg-blue-50 border-l-4 border-blue-400 rounded-r-xl p-4 mb-4">
      <p class="text-blue-700 font-bold text-sm mb-2">Cómo se usa</p>
      <ol class="text-blue-800 text-sm space-y-1 list-decimal list-inside">
        <li>Entrená un modelo en <b>teachablemachine.withgoogle.com</b> (modo Imagen) con fotos de tu objeto.</li>
        <li><b>Export Model</b> → <b>Upload my model</b> → copiá el link y pegalo arriba → <b>Cargar modelo</b>.</li>
        <li>Cargá <code>explorador.py</code> en el hub y dale play.</li>
        <li>Acá: <b>Encender cámara</b> → apuntá al objeto y <b>Fijar color</b> → <b>Conectar hub</b> → <b>Empezar a enviar</b>.</li>
      </ol>
    </div>

    <div class="bg-orange-50 border-l-4 border-orange-400 rounded-r-xl p-4 mb-6">
      <p class="text-orange-700 font-bold text-sm mb-1">💡 Qué le llega al hub</p>
      <p class="text-orange-800 text-sm">
        4 bytes: <b>clase</b> (qué objeto, índice del modelo), <b>confianza</b> (0-100),
        <b>cx</b> (centro horizontal del objeto, 50 = centrado) y <b>tamaño</b> (0-100, más grande = más cerca).
        El reconocimiento lo hace Teachable Machine; el <b>cx</b> y el <b>tamaño</b> salen del color que fijaste.
      </p>
    </div>

    <h2 class="text-lg font-bold text-gray-900 mb-3">Programa del hub (explorador)</h2>
    <p class="text-gray-600 text-sm mb-3">
      Lee los 4 bytes que manda este teléfono. El programa completo está en
      <code>programs/explorador.py</code>; esto es solo la parte de lectura.
    </p>
    <div class="relative">
      <button id="btn-copy"
              class="absolute top-3 right-3 bg-slate-700 text-white text-xs px-3 py-1 rounded-md hover:bg-slate-600 transition-colors">
        Copiar
      </button>
      <pre id="hub-code" class="bg-slate-900 text-slate-100 text-xs sm:text-sm rounded-xl p-4 pt-10 overflow-auto font-mono leading-relaxed"><code>from pybricks.hubs import PrimeHub
from pybricks.messaging import AppData
from pybricks.tools import wait

hub = PrimeHub()

# 4 bytes en el modo 0: clase, confianza, cx, area
app = AppData([(0, 4)])

CLASE_OBJETIVO = 1   # que clase del modelo buscamos

while True:
    clase, conf, cx, area = app.get_bytes(mode=0)
    if clase == CLASE_OBJETIVO and conf &gt; 70:
        # cx: 50 = centrado | area: mas grande = mas cerca
        print("objetivo!", "cx", cx, "area", area)
        hub.display.char("O")
    else:
        hub.display.char("-")
    wait(50)
</code></pre>
    </div>

  </div>

  <script>
    // La comunicación con el hub vive en un módulo aparte, reutilizable.
    import { PybricksHub, isWebBluetoothSupported } from '../lib/pybricks-ble.js';

    // tmImage es global (lo cargan los <script is:inline> de arriba).
    declare const tmImage: any;

    const SEND_INTERVAL_MS = 100;   // 10 envíos por segundo
    const PREDICT_INTERVAL_MS = 150; // correr el modelo ~7 veces por segundo
    const HUE_TOL = 22;             // tolerancia de tono para el blob (grados)
    const SAT_MIN = 30;             // saturación mínima para contar un píxel

    // ── Estado ──────────────────────────────────────────────────────────────
    const hub = new PybricksHub();
    let cameraOn = false;
    let streaming = false;
    let sendTimer: number | null = null;
    let model: any = null;
    let targetHue: number | null = null; // tono del objeto (calibrado)
    // Último dato calculado: [clase, confianza, cx, area]
    let lastData = [0, 0, 50, 0];

    // ── Elementos ───────────────────────────────────────────────────────────
    const $ = (id: string) => document.getElementById(id)!;
    const video = $('video') as HTMLVideoElement;
    const sampler = document.createElement('canvas');
    sampler.width = 64; sampler.height = 64;
    const sctx = sampler.getContext('2d', { willReadFrequently: true })!;

    function log(msg: string) {
      const el = $('log');
      const t = new Date().toLocaleTimeString();
      el.textContent += `[${t}] ${msg}\n`;
      el.scrollTop = el.scrollHeight;
    }

    function setStatus(state: string, text: string) {
      const dot = $('status-dot');
      const colors: Record<string, string> = {
        off: 'bg-slate-500',
        connecting: 'bg-yellow-400 animate-pulse',
        on: 'bg-green-400',
        error: 'bg-red-500',
      };
      dot.className = `w-3 h-3 rounded-full ${colors[state] || colors.off}`;
      $('status-text').textContent = text;
    }

    // ── Soporte ─────────────────────────────────────────────────────────────
    if (!isWebBluetoothSupported()) {
      $('unsupported').classList.remove('hidden');
      $('btn-connect').setAttribute('disabled', 'true');
    }

    // ── Cargar modelo de Teachable Machine ───────────────────────────────────
    $('btn-load-model').addEventListener('click', async () => {
      let url = ($('model-url') as HTMLInputElement).value.trim();
      if (!url) { alert('Pegá el link del modelo de Teachable Machine.'); return; }
      if (!url.endsWith('/')) url += '/';
      try {
        $('model-status').textContent = 'Cargando modelo…';
        log('Cargando modelo desde ' + url);
        model = await tmImage.load(url + 'model.json', url + 'metadata.json');
        const n = model.getTotalClasses();
        $('model-status').textContent = `Modelo cargado: ${n} clases.`;
        log(`Modelo cargado (${n} clases).`);
        predictLoop();
      } catch (err: any) {
        $('model-status').textContent = 'Error al cargar el modelo.';
        log('Error de modelo: ' + err.message);
        alert('No se pudo cargar el modelo: ' + err.message);
      }
    });

    // ── Cámara ──────────────────────────────────────────────────────────────
    $('btn-camera').addEventListener('click', async () => {
      if (cameraOn) return;
      try {
        const stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: { ideal: 'environment' } },
          audio: false,
        });
        video.srcObject = stream;
        await video.play();
        cameraOn = true;
        $('cam-hint').classList.add('hidden');
        $('btn-camera').textContent = 'Cámara encendida';
        $('btn-camera').setAttribute('disabled', 'true');
        $('btn-camera').classList.add('opacity-40');
        $('btn-calibrate').removeAttribute('disabled');
        $('btn-stream').removeAttribute('disabled');
        log('Cámara encendida.');
        requestAnimationFrame(blobLoop);
      } catch (err: any) {
        log('Error de cámara: ' + err.message);
        alert('No se pudo acceder a la cámara: ' + err.message);
      }
    });

    // Convierte RGB (0-255) a HSV con H en grados (0-360), S y V en 0-100.
    function rgbToHsv(r: number, g: number, b: number) {
      r /= 255; g /= 255; b /= 255;
      const max = Math.max(r, g, b), min = Math.min(r, g, b);
      const d = max - min;
      let h = 0;
      if (d !== 0) {
        if (max === r) h = ((g - b) / d) % 6;
        else if (max === g) h = (b - r) / d + 2;
        else h = (r - g) / d + 4;
        h *= 60;
        if (h < 0) h += 360;
      }
      const s = max === 0 ? 0 : d / max;
      return [h, s * 100, max * 100];
    }

    // ── Calibrar color del objeto (promedio de la mira central) ──────────────
    $('btn-calibrate').addEventListener('click', () => {
      if (!cameraOn || !video.videoWidth) return;
      const vw = video.videoWidth, vh = video.videoHeight;
      const box = Math.min(vw, vh) * 0.25;
      sctx.drawImage(video, (vw - box) / 2, (vh - box) / 2, box, box, 0, 0, 16, 16);
      const { data } = sctx.getImageData(0, 0, 16, 16);
      let r = 0, g = 0, b = 0;
      const n = data.length / 4;
      for (let i = 0; i < data.length; i += 4) { r += data[i]; g += data[i + 1]; b += data[i + 2]; }
      const [h] = rgbToHsv(r / n, g / n, b / n);
      targetHue = h;
      $('cx-marker').classList.remove('hidden');
      log(`Color del objeto fijado: tono ${Math.round(h)}°`);
    });

    // Distancia angular entre dos tonos (0-360, circular).
    function hueDist(a: number, b: number) {
      const d = Math.abs(a - b) % 360;
      return d > 180 ? 360 - d : d;
    }

    // ── Loop del blob: calcula cx y area del color objetivo ──────────────────
    function blobLoop() {
      if (!cameraOn) return;
      if (video.videoWidth && targetHue !== null) {
        const W = sampler.width, H = sampler.height;
        sctx.drawImage(video, 0, 0, W, H);
        const { data } = sctx.getImageData(0, 0, W, H);
        let sumX = 0, count = 0;
        for (let p = 0; p < data.length; p += 4) {
          const [h, s, v] = rgbToHsv(data[p], data[p + 1], data[p + 2]);
          if (s >= SAT_MIN && v >= 15 && hueDist(h, targetHue) <= HUE_TOL) {
            const px = (p / 4) % W;
            sumX += px; count++;
          }
        }
        let cx = 50, area = 0;
        if (count > 0) {
          cx = Math.round((sumX / count) / W * 100);
          area = Math.min(100, Math.round((count / (W * H)) * 100));
        }
        lastData[2] = cx;
        lastData[3] = area;
        // UI
        $('val-cx').textContent = String(cx);
        $('val-area').textContent = String(area);
        ($('cx-marker') as HTMLElement).style.left = cx + '%';
      }
      requestAnimationFrame(blobLoop);
    }

    // ── Loop del modelo: clase + confianza ───────────────────────────────────
    async function predictLoop() {
      if (model && cameraOn && video.videoWidth) {
        try {
          const preds = await model.predict(video);
          let best = 0;
          for (let i = 1; i < preds.length; i++) {
            if (preds[i].probability > preds[best].probability) best = i;
          }
          const conf = Math.round(preds[best].probability * 100);
          lastData[0] = best;
          lastData[1] = conf;
          $('pred-name').textContent = preds[best].className;
          ($('pred-bar') as HTMLElement).style.width = conf + '%';
          $('pred-conf').textContent = `confianza ${conf}% · clase ${best}`;
        } catch (err: any) {
          log('Error de predicción: ' + err.message);
        }
      }
      if (model) setTimeout(predictLoop, PREDICT_INTERVAL_MS);
    }

    // ── Bluetooth ───────────────────────────────────────────────────────────
    $('btn-connect').addEventListener('click', async () => {
      if (hub.connected) { hub.disconnect(); return; }
      try {
        setStatus('connecting', 'Buscando hub…');
        log('Buscando hub…');
        await hub.connect();
      } catch (err: any) {
        setStatus('error', 'Error de conexión');
        log('Error BLE: ' + err.message);
      }
    });

    hub.addEventListener('connect', (e: any) => {
      const name = e.detail.name || 'hub';
      setStatus('on', 'Conectado a ' + name);
      $('btn-connect').textContent = 'Desconectar';
      log('¡Conectado a ' + name + '! Listo para enviar.');
    });

    hub.addEventListener('disconnect', () => {
      setStatus('off', 'Desconectado');
      $('btn-connect').textContent = 'Conectar hub';
      log('Hub desconectado.');
      stopStreaming();
    });

    hub.addEventListener('stdout', (e: any) => {
      const txt = e.detail.text.replace(/\s+$/, '');
      if (txt) log('hub » ' + txt);
    });

    // ── Envío al hub ──────────────────────────────────────────────────────────
    $('btn-stream').addEventListener('click', () => {
      if (streaming) { stopStreaming(); return; }
      if (!hub.connected) { alert('Primero conectá el hub.'); return; }
      streaming = true;
      $('btn-stream').textContent = '⏸ Detener envío';
      $('btn-stream').classList.replace('bg-green-600', 'bg-red-600');
      $('btn-stream').classList.replace('hover:bg-green-700', 'hover:bg-red-700');
      sendTimer = window.setInterval(sendData, SEND_INTERVAL_MS);
      log('Enviando datos al hub…');
    });

    function stopStreaming() {
      streaming = false;
      if (sendTimer) { clearInterval(sendTimer); sendTimer = null; }
      const b = $('btn-stream');
      b.textContent = '▶ Empezar a enviar';
      b.classList.replace('bg-red-600', 'bg-green-600');
      b.classList.replace('hover:bg-red-700', 'hover:bg-green-700');
    }

    async function sendData() {
      if (!hub.connected) return;
      // 4 bytes: clase, confianza, cx, area (todos 0-255).
      const bytes = [
        Math.min(255, lastData[0]),
        Math.min(100, lastData[1]),
        Math.min(100, lastData[2]),
        Math.min(100, lastData[3]),
      ];
      try {
        await hub.sendAppData(bytes); // descarta si el envío anterior sigue en curso
      } catch (err: any) {
        log('Error al enviar: ' + err.message);
      }
    }

    // ── Copiar código ─────────────────────────────────────────────────────────
    $('btn-copy').addEventListener('click', async () => {
      const code = $('hub-code').textContent || '';
      try {
        await navigator.clipboard.writeText(code);
        $('btn-copy').textContent = '¡Copiado!';
        setTimeout(() => ($('btn-copy').textContent = 'Copiar'), 1500);
      } catch {
        $('btn-copy').textContent = 'Error';
      }
    });
  </script>

</BaseLayout>
