---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Tutoriales de robótica con Pybricks para WRO' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const challenges = [
  { num: '00', slug: '00-setup', title: 'Setup del ambiente' },
  { num: '01', slug: '01-hola-hub', title: 'Hola Hub' },
  { num: '02', slug: '02-movimiento', title: 'Movimiento básico' },
  { num: '03', slug: '03-sensor-color', title: 'Sensor de color' },
  { num: '04', slug: '04-sensor-ultrasonico', title: 'Sensor ultrasónico' },
  { num: '05', slug: '05-mision-wro', title: 'Misión WRO' },
];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — WRO Pybricks</title>
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
</head>
<body class="min-h-screen bg-gray-50 flex flex-col font-sans text-gray-900">

  <!-- Header -->
  <header class="bg-slate-900 text-white shadow-lg sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href={`${base}/`} class="flex items-center gap-3 hover:opacity-80 transition-opacity">
        <span class="text-2xl">🤖</span>
        <div>
          <div class="font-bold text-base leading-tight">WRO Pybricks</div>
          <div class="text-slate-400 text-xs">Tomas · Gael · Juan Marcos</div>
        </div>
      </a>

      <nav class="flex items-center gap-1">
        <a href={`${base}/`}
           class="hidden sm:block px-3 py-1.5 rounded-lg text-sm text-slate-300 hover:text-white hover:bg-slate-700 transition-colors">
          Inicio
        </a>

        <!-- Dropdown challenges -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm text-slate-300 hover:text-white hover:bg-slate-700 transition-colors cursor-pointer">
            Challenges
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute right-0 top-full mt-1 w-64 bg-slate-800 rounded-xl shadow-2xl border border-slate-700
                      invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-150 z-50">
            {challenges.map(c => (
              <a href={`${base}/challenges/${c.slug}`}
                 class="flex items-center gap-3 px-4 py-2.5 hover:bg-slate-700 first:rounded-t-xl last:rounded-b-xl transition-colors">
                <span class="text-xs bg-orange-500 text-white rounded-full w-6 h-6 flex items-center justify-center font-bold flex-shrink-0">
                  {c.num}
                </span>
                <span class="text-sm text-slate-200">{c.title}</span>
              </a>
            ))}
          </div>
        </div>
      </nav>
    </div>
  </header>

  <!-- Main -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-slate-900 text-slate-400 mt-16">
    <div class="max-w-5xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <div class="text-sm">🤖 WRO Pybricks Challenges · {new Date().getFullYear()}</div>
      <a href={`${base}/profe`}
         class="text-xs text-slate-600 hover:text-slate-400 transition-colors">
        Acceso Profesor
      </a>
    </div>
  </footer>

</body>
</html>
