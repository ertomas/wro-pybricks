---
import BaseLayout from './BaseLayout.astro';

interface Props {
  number: number;
  slug: string;
  title: string;
  time: string;
  difficulty: number;
  objectives: string[];
  prevHref?: string;
  prevTitle?: string;
  nextHref?: string;
  nextTitle?: string;
}

const { number, title, time, difficulty, objectives, prevHref, prevTitle, nextHref, nextTitle } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const difficultyLabels = ['', 'Principiante', 'Fácil', 'Intermedio', 'Avanzado'];
const difficultyColors = ['', 'text-green-600', 'text-blue-600', 'text-orange-500', 'text-red-600'];
---

<BaseLayout title={`Challenge ${String(number).padStart(2,'0')}: ${title}`}>

  <div class="max-w-3xl mx-auto px-4 py-8">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6 flex items-center gap-2">
      <a href={`${base}/`} class="hover:text-orange-500 transition-colors">Inicio</a>
      <span>/</span>
      <span class="text-gray-900 font-medium">Challenge {String(number).padStart(2,'0')}</span>
    </nav>

    <!-- Challenge header -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 mb-8">
      <div class="flex items-start gap-4">
        <div class="bg-orange-500 text-white text-2xl font-black rounded-xl w-14 h-14 flex items-center justify-center flex-shrink-0">
          {String(number).padStart(2,'0')}
        </div>
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl font-bold text-gray-900 mb-2">{title}</h1>
          <div class="flex flex-wrap items-center gap-4 text-sm">
            <span class="flex items-center gap-1 text-gray-600">
              <span>⏱</span> {time}
            </span>
            <span class={`font-semibold ${difficultyColors[difficulty]}`}>
              {'★'.repeat(difficulty)}{'☆'.repeat(4 - difficulty)} {difficultyLabels[difficulty]}
            </span>
          </div>
        </div>
      </div>

      <div class="mt-5 pt-5 border-t border-gray-100">
        <p class="text-sm font-semibold text-gray-700 mb-2 uppercase tracking-wide">Al terminar este challenge vas a poder:</p>
        <ul class="space-y-1.5">
          {objectives.map(obj => (
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <span class="text-orange-500 mt-0.5 flex-shrink-0">✓</span>
              <span>{obj}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Challenge content -->
    <div class="prose-challenge">
      <slot />
    </div>

    <!-- Prev / Next navigation -->
    <div class="mt-12 flex gap-4">
      {prevHref ? (
        <a href={`${base}${prevHref}`}
           class="flex-1 flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:border-orange-300 hover:shadow-md transition-all group">
          <span class="text-2xl group-hover:-translate-x-1 transition-transform">←</span>
          <div>
            <div class="text-xs text-gray-500">Anterior</div>
            <div class="text-sm font-semibold text-gray-800">{prevTitle}</div>
          </div>
        </a>
      ) : <div class="flex-1" />}

      {nextHref ? (
        <a href={`${base}${nextHref}`}
           class="flex-1 flex items-center justify-end gap-3 bg-orange-500 text-white rounded-xl p-4 hover:bg-orange-600 hover:shadow-md transition-all group">
          <div class="text-right">
            <div class="text-xs text-orange-200">Siguiente</div>
            <div class="text-sm font-semibold">{nextTitle}</div>
          </div>
          <span class="text-2xl group-hover:translate-x-1 transition-transform">→</span>
        </a>
      ) : (
        <a href={`${base}/`}
           class="flex-1 flex items-center justify-end gap-3 bg-green-600 text-white rounded-xl p-4 hover:bg-green-700 hover:shadow-md transition-all">
          <div class="text-right">
            <div class="text-xs text-green-200">¡Felicitaciones!</div>
            <div class="text-sm font-semibold">Ver todos los challenges</div>
          </div>
          <span class="text-2xl">🏆</span>
        </a>
      )}
    </div>

  </div>
</BaseLayout>

<style is:global>
  /* Estilos para el contenido de los challenges */
  .prose-challenge h2 {
    @apply text-xl font-bold text-gray-900 mt-10 mb-4 flex items-center gap-2;
  }
  .prose-challenge h3 {
    @apply text-base font-bold text-gray-800 mt-6 mb-3;
  }
  .prose-challenge p {
    @apply text-gray-700 leading-relaxed mb-4;
  }
  .prose-challenge ul {
    @apply space-y-2 mb-4;
  }
  .prose-challenge ul li {
    @apply flex items-start gap-2 text-gray-700;
  }
  .prose-challenge ol {
    @apply space-y-3 mb-4;
  }

  /* Cajas de tip/warning */
  .tip {
    @apply bg-blue-50 border-l-4 border-blue-400 rounded-r-xl p-4 mb-4;
  }
  .tip-title {
    @apply text-blue-700 font-bold text-sm mb-1;
  }
  .tip p {
    @apply text-blue-800 text-sm mb-0;
  }
  .warning {
    @apply bg-orange-50 border-l-4 border-orange-400 rounded-r-xl p-4 mb-4;
  }
  .warning-title {
    @apply text-orange-700 font-bold text-sm mb-1;
  }
  .warning p {
    @apply text-orange-800 text-sm mb-0;
  }

  /* Pasos numerados */
  .steps {
    @apply space-y-6 mb-6;
  }
  .step {
    @apply flex gap-4;
  }
  .step-number {
    @apply bg-orange-500 text-white rounded-full w-8 h-8 flex items-center justify-center font-bold text-sm flex-shrink-0 mt-0.5;
  }
  .step-content {
    @apply flex-1;
  }
  .step-content h4 {
    @apply font-bold text-gray-900 mb-1;
  }
  .step-content p {
    @apply text-gray-700 text-sm mb-2;
  }

  /* Caja de entrega */
  .entrega-box {
    @apply bg-green-50 border border-green-200 rounded-2xl p-6 mt-8;
  }
  .entrega-box h2 {
    @apply text-green-800 mt-0;
  }
  .entrega-item {
    @apply flex items-start gap-3 py-2 border-b border-green-100 last:border-0;
  }
  .entrega-item span {
    @apply text-sm text-green-900;
  }

  /* Caja de bonus */
  .bonus-box {
    @apply bg-purple-50 border border-purple-200 rounded-2xl p-6 mt-6;
  }
  .bonus-box h2 {
    @apply text-purple-800 mt-0;
  }
  .bonus-box p, .bonus-box li {
    @apply text-purple-900;
  }
</style>
